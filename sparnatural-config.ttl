@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix dash:   <http://datashapes.org/dash#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .

@prefix volipi: <http://data.sparna.fr/ontologies/volipi#> .
@prefix guide:  <https://w3id.org/guia#> .
@prefix sch:    <https://schema.org/> .

<http://guia-project.eu/sparnatural-config>
    a owl:Ontology .

##################################################
# NODE SHAPES X
##################################################

guide:UniversityCenterShape
    a sh:NodeShape ;
    sh:targetClass guide:UniversityCenter ;
    rdfs:label "University Center"@en ;
    rdfs:label "Centro universitario"@es ;
    volipi:iconName "fa-solid fa-building" ;
    sh:property guide:UniversityCenter-name ;
    sh:property guide:UniversityCenter-offers .

guide:DegreeShape
    a sh:NodeShape ;
    sh:targetClass guide:Degree ;
    rdfs:label "Degree"@en ;
    rdfs:label "Titulación"@es ;
    volipi:iconName "fa-solid fa-graduation-cap" ;
    sh:property guide:Degree-name ;
    sh:property guide:Degree-hasCourse .

guide:CourseShape
    a sh:NodeShape ;
    sh:targetClass guide:Course ;
    rdfs:label "Course"@en ;
    rdfs:label "Asignatura"@es ;
    volipi:iconName "fa-solid fa-book" ;
    sh:property guide:Course-name ;
    sh:property guide:Course-hasInstance .

guide:CourseGuideShape
    a sh:NodeShape ;
    sh:targetClass guide:CourseGuide ;
    rdfs:label "Course Guide"@en ;
    rdfs:label "Guía docente"@es ;
    volipi:iconName "fa-regular fa-file-lines" ;
    sh:property guide:CourseGuide-name ;
    sh:property guide:CourseGuide-director ;
    sh:property guide:CourseGuide-instructor ;
    sh:property guide:CourseGuide-hasCompetency ;
    sh:property guide:CourseGuide-hasLearningResult ;
    sh:property guide:CourseGuide-hasEvaluation .

guide:LecturerShape
    a sh:NodeShape ;
    sh:targetClass guide:Lecturer ;
    rdfs:label "Lecturer"@en ;
    rdfs:label "Profesorado"@es ;
    volipi:iconName "fa-solid fa-chalkboard-user" ;
    sh:property guide:Lecturer-name .

guide:CompetencyShape
    a sh:NodeShape ;
    sh:targetClass guide:Competency ;
    rdfs:label "Competency"@en ;
    rdfs:label "Competencia"@es ;
    volipi:iconName "fa-solid fa-lightbulb" ;
    sh:property guide:Competency-name .

guide:LearningResultShape
    a sh:NodeShape ;
    sh:targetClass guide:LearningResult ;
    rdfs:label "Learning Result"@en ;
    rdfs:label "Resultado de aprendizaje"@es ;
    volipi:iconName "fa-solid fa-circle-check" ;
    sh:property guide:LearningResult-name .

guide:EvaluationSystemShape
    a sh:NodeShape ;
    sh:targetClass guide:EvaluationSystem ;
    rdfs:label "Evaluation System"@en ;
    rdfs:label "Sistema de evaluación"@es ;
    volipi:iconName "fa-solid fa-list-check" ;
    sh:property guide:EvaluationSystem-hasTrial .

guide:EvaluationTrialShape
    a sh:NodeShape ;
    sh:targetClass guide:EvaluationTrial ;
    rdfs:label "Evaluation Trial"@en ;
    rdfs:label "Prueba de evaluación"@es ;
    volipi:iconName "fa-solid fa-clipboard-check" .

##################################################
# LABEL PROPERTIES
##################################################

guide:UniversityCenter-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:Degree-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:Course-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:CourseGuide-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:Lecturer-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:Competency-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

guide:LearningResult-name
    a sh:PropertyShape ;
    sh:path sch:name ;
    sh:name "name"@en ;
    sh:name "nombre"@es ;
    dash:propertyRole dash:LabelRole .

##################################################
# OBJECT PROPERTIES
##################################################

guide:UniversityCenter-offers
    a sh:PropertyShape ;
    sh:path guide:offers ;
    sh:name "offers"@en ;
    sh:name "ofrece"@es ;
    sh:class guide:Degree .

guide:Degree-hasCourse
    a sh:PropertyShape ;
    sh:path guide:hasCourse ;
    sh:name "has course"@en ;
    sh:name "tiene asignatura"@es ;
    sh:class guide:Course .

guide:Course-hasInstance
    a sh:PropertyShape ;
    sh:path sch:hasCourseInstance ;
    sh:name "has course instance"@en ;
    sh:name "tiene instancia"@es ;
    sh:class guide:CourseGuide .

guide:CourseGuide-director
    a sh:PropertyShape ;
    sh:path sch:director ;
    sh:name "director"@en ;
    sh:name "director"@es ;
    sh:class guide:Lecturer .

guide:CourseGuide-instructor
    a sh:PropertyShape ;
    sh:path sch:instructor ;
    sh:name "instructor"@en ;
    sh:name "profesor"@es ;
    sh:class guide:Lecturer .

guide:CourseGuide-hasCompetency
    a sh:PropertyShape ;
    sh:path guide:hasCompetency ;
    sh:name "has competency"@en ;
    sh:name "tiene competencia"@es ;
    sh:class guide:Competency .

guide:CourseGuide-hasLearningResult
    a sh:PropertyShape ;
    sh:path guide:hasLearningResult ;
    sh:name "has learning result"@en ;
    sh:name "tiene resultado de aprendizaje"@es ;
    sh:class guide:LearningResult .

guide:CourseGuide-hasEvaluation
    a sh:PropertyShape ;
    sh:path guide:hasEvaluation ;
    sh:name "has evaluation"@en ;
    sh:name "tiene evaluación"@es ;
    sh:class guide:EvaluationSystem .

guide:EvaluationSystem-hasTrial
    a sh:PropertyShape ;
    sh:path guide:hasEvaluationTrial ;
    sh:name "has evaluation trial"@en ;
    sh:name "tiene prueba de evaluación"@es ;
    sh:class guide:EvaluationTrial .
